<section class="collaborators" aria-label="Collaborating organisations">
  <div class="row g-4">
    {{#each collaborators}}
    <div class="col-sm-6 col-md-4 d-flex align-items-center">
      <a href="{{websiteUrl}}" class="d-flex align-items-center text-decoration-none" target="_blank" rel="noopener noreferrer">
        <img src="{{logoUrl}}" alt="{{name}} logo" class="me-3" style="height: 48px; width: auto;">
        <span>{{name}}</span>
      </a>
    </div>
    {{/each}}
  </div>
</section>
