<section class="py-5 mt-5">
  <div class="container">
    <h1>Contributing</h1>
    <p class="lead">We welcome contributions from amateur radio operators, researchers, and developers.</p>

    <h2 class="mt-4">Contribution Areas</h2>
    <p>There are many ways to contribute to the project:</p>
    <div class="row g-3 mt-2">
      {{#each content.areas}}
      <div class="col-md-6 col-lg-4">
        <div class="card h-100">
          <div class="card-body">
            <p class="mb-0">{{this}}</p>
          </div>
        </div>
      </div>
      {{/each}}
    </div>

    <h2 class="mt-5">Development Setup</h2>
    <p>Get the project running locally for development:</p>
    {{#each content.developmentSetup}}
    {{> code-block language="bash" code=this}}
    {{/each}}

    <h2 class="mt-5">Community</h2>
    <p>Connect with the project team and other contributors:</p>
    <h2 class="mt-5">License</h2>
    <p>This project is licensed under the <strong>{{content.license}}</strong> License. By contributing, you agree that your contributions will be licensed under the same terms.</p>
    <p>See the <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT License</a> for full details.</p>
  </div>
</section>
