<section class="py-5 mt-5">
  <div class="container">
    <h1>Resources</h1>
    <p class="lead">External resources, references, and background reading for DTN and amateur radio networking.</p>

    {{#each resources.categories}}
    <h2 class="mt-4">{{name}}</h2>
    <div class="list-group mb-3">
      {{#each links}}
      <a href="{{url}}" class="list-group-item list-group-item-action" target="_blank" rel="noopener noreferrer">
        <div class="d-flex w-100 justify-content-between">
          <h3 class="h6 mb-1">{{title}}</h3>
        </div>
        <p class="mb-1 small text-muted">{{description}}</p>
      </a>
      {{/each}}
    </div>
    {{/each}}
  </div>
</section>
