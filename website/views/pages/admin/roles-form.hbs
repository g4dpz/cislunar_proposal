<section class="py-5 mt-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="h3 mb-0">{{#if content.isEdit}}Edit Role{{else}}Create Role{{/if}}</h1>
          <a href="/admin/roles" class="btn btn-outline-secondary btn-sm">Back to Roles</a>
        </div>

        {{> flash-message}}
        {{> form-errors}}

        <div class="card shadow-sm">
          <div class="card-body">
            <form method="POST" action="{{#if content.isEdit}}/admin/roles/{{content.role.id}}{{else}}/admin/roles{{/if}}" novalidate>
              <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" name="name"
                       value="{{content.role.name}}" required>
              </div>

              <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description"
                          rows="3">{{content.role.description}}</textarea>
              </div>

              <div class="d-grid">
                <button type="submit" class="btn btn-primary">
                  {{#if content.isEdit}}Update Role{{else}}Create Role{{/if}}
                </button>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
