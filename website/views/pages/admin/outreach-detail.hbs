<section class="py-5 mt-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="h3 mb-0">Contact Details</h1>
          <a href="/admin/outreach" class="btn btn-outline-secondary btn-sm">Back to Outreach</a>
        </div>

        {{> flash-message}}

        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <dl class="row mb-0">
              <dt class="col-sm-4">Name</dt>
              <dd class="col-sm-8">{{content.contact.name}}</dd>

              <dt class="col-sm-4">Type</dt>
              <dd class="col-sm-8"><span class="badge bg-info text-dark">{{content.contact.contactType}}</span></dd>

              <dt class="col-sm-4">Status</dt>
              <dd class="col-sm-8"><span class="badge bg-primary">{{content.contact.status}}</span></dd>

              <dt class="col-sm-4">URL</dt>
              <dd class="col-sm-8">
                {{#if content.contact.contactUrl}}
                <a href="{{content.contact.contactUrl}}" target="_blank" rel="noopener noreferrer">{{content.contact.contactUrl}}</a>
                {{else}}
                <span class="text-muted">—</span>
                {{/if}}
              </dd>

              <dt class="col-sm-4">Callsign</dt>
              <dd class="col-sm-8">{{#if content.contact.callsign}}{{content.contact.callsign}}{{else}}<span class="text-muted">—</span>{{/if}}</dd>

              <dt class="col-sm-4">Email</dt>
              <dd class="col-sm-8">{{#if content.contact.email}}{{content.contact.email}}{{else}}<span class="text-muted">—</span>{{/if}}</dd>

              <dt class="col-sm-4">Notes</dt>
              <dd class="col-sm-8">{{#if content.contact.notes}}{{content.contact.notes}}{{else}}<span class="text-muted">—</span>{{/if}}</dd>

              <dt class="col-sm-4">Contacted By</dt>
              <dd class="col-sm-8">{{#if content.contact.contactedBy}}{{content.contact.contactedBy}}{{else}}<span class="text-muted">—</span>{{/if}}</dd>

              <dt class="col-sm-4">Contacted Date</dt>
              <dd class="col-sm-8">{{#if content.contact.contactedDate}}{{content.contact.contactedDate}}{{else}}<span class="text-muted">—</span>{{/if}}</dd>

              <dt class="col-sm-4">Created</dt>
              <dd class="col-sm-8">{{content.contact.createdAt}}</dd>

              <dt class="col-sm-4">Last Updated</dt>
              <dd class="col-sm-8">{{content.contact.lastUpdated}}</dd>
            </dl>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a href="/admin/outreach/{{content.contact.id}}/edit" class="btn btn-primary">Edit Contact</a>
          <form method="POST" action="/admin/outreach/{{content.contact.id}}/delete" onsubmit="return confirm('Are you sure you want to delete this contact? This action cannot be undone.');">
            <button type="submit" class="btn btn-danger">Delete Contact</button>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>
