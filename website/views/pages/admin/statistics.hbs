<section class="py-5 mt-5">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="h3 mb-0"><i class="bi bi-bar-chart-line me-2"></i>Access Statistics</h1>
          {{#if content.includeOwner}}
            <a href="/admin/statistics" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-funnel me-1"></i>Exclude My Traffic
            </a>
          {{else}}
            <a href="/admin/statistics?include_owner=true" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-funnel-fill me-1"></i>Include My Traffic
            </a>
          {{/if}}
        </div>

        {{#if errors}}
          {{#each errors}}
            <div class="alert alert-danger" role="alert">
              <i class="bi bi-exclamation-triangle me-2"></i>{{this}}
            </div>
          {{/each}}
        {{/if}}

        {{#if content.error}}
          <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{content.error}}
          </div>
        {{/if}}

        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
          <div class="col-md-3">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <div class="text-muted small mb-1"><i class="bi bi-globe me-1"></i>Total Requests</div>
                <div class="h4 mb-1">{{content.totalRequests}}</div>
                <div class="small">
                  <span class="text-success">{{content.humanRequests}} human ({{content.humanPercent}}%)</span>
                  <br>
                  <span class="text-secondary">{{content.botRequests}} bot ({{content.botPercent}}%)</span>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <div class="text-muted small mb-1"><i class="bi bi-people me-1"></i>Unique Visitors</div>
                <div class="h4 mb-0">{{content.uniqueVisitors}}</div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <div class="text-muted small mb-1"><i class="bi bi-file-earmark-text me-1"></i>Page Views</div>
                <div class="h4 mb-0">{{content.pageViews}}</div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <div class="text-muted small mb-1"><i class="bi bi-hdd me-1"></i>Bandwidth</div>
                <div class="h4 mb-0">{{content.bandwidth}}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Requests by Hour -->
        <div class="card shadow-sm mb-4">
          <div class="card-header">
            <h5 class="card-title mb-0"><i class="bi bi-clock me-2"></i>Requests by Hour</h5>
          </div>
          <div class="card-body">
            {{#if content.hourlyData}}
              <div class="d-flex align-items-end justify-content-between" style="height: 150px; gap: 2px;">
                {{#each content.hourlyData}}
                  <div class="d-flex flex-column align-items-center flex-fill">
                    <div class="bg-primary rounded-top w-100" style="height: {{this.heightPercent}}%; min-height: 2px;" title="{{this.hour}}:00 — {{this.count}} requests"></div>
                    <small class="text-muted mt-1" style="font-size: 0.65rem;">{{this.hour}}</small>
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="text-muted mb-0">No data available.</p>
            {{/if}}
          </div>
        </div>

        <div class="row g-4">
          <!-- Top Pages -->
          <div class="col-lg-6">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-file-earmark me-2"></i>Top Pages</h5>
              </div>
              <div class="card-body p-0">
                {{#if content.topPages}}
                  <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Path</th>
                          <th class="text-end">Views</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each content.topPages}}
                          <tr>
                            <td><code class="small">{{this.path}}</code></td>
                            <td class="text-end">{{this.count}}</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                {{else}}
                  <p class="text-muted p-3 mb-0">No page view data available.</p>
                {{/if}}
              </div>
            </div>
          </div>

          <!-- Top Visitors by IP -->
          <div class="col-lg-6">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-pc-display me-2"></i>Top Visitors</h5>
              </div>
              <div class="card-body p-0">
                {{#if content.topIPs}}
                  <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>IP Address</th>
                          <th class="text-end">Requests</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each content.topIPs}}
                          <tr>
                            <td>
                              <code class="small">{{this.ip}}</code>
                              {{#if this.isBot}}
                                <span class="badge bg-secondary ms-1">bot</span>
                              {{/if}}
                            </td>
                            <td class="text-end">{{this.count}}</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                {{else}}
                  <p class="text-muted p-3 mb-0">No visitor data available.</p>
                {{/if}}
              </div>
            </div>
          </div>
        </div>

        <!-- Status Codes & Browsers -->
        <div class="row g-4 mt-0">
          <!-- HTTP Status Codes -->
          <div class="col-lg-6">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-signpost me-2"></i>HTTP Status Codes</h5>
              </div>
              <div class="card-body p-0">
                {{#if content.statusCodes}}
                  <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Code</th>
                          <th>Count</th>
                          <th class="text-end">%</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each content.statusCodes}}
                          <tr>
                            <td><span class="badge {{this.badgeClass}}">{{this.code}}</span></td>
                            <td>{{this.count}}</td>
                            <td class="text-end">{{this.percent}}%</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                {{else}}
                  <p class="text-muted p-3 mb-0">No status code data available.</p>
                {{/if}}
              </div>
            </div>
          </div>

          <!-- Browsers -->
          <div class="col-lg-6">
            <div class="card shadow-sm h-100">
              <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-browser-chrome me-2"></i>Browsers</h5>
              </div>
              <div class="card-body p-0">
                {{#if content.browsers}}
                  <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Browser</th>
                          <th>Visits</th>
                          <th class="text-end">%</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each content.browsers}}
                          <tr>
                            <td>{{this.name}}</td>
                            <td>{{this.count}}</td>
                            <td class="text-end">{{this.percent}}%</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                {{else}}
                  <p class="text-muted p-3 mb-0">No browser data available.</p>
                {{/if}}
              </div>
            </div>
          </div>
        </div>

        <!-- Requests by Day -->
        <div class="card shadow-sm mt-4">
          <div class="card-header">
            <h5 class="card-title mb-0"><i class="bi bi-calendar3 me-2"></i>Requests by Day (Last 30 Days)</h5>
          </div>
          <div class="card-body">
            {{#if content.dailyData}}
              {{#each content.dailyData}}
                <div class="d-flex align-items-center mb-1">
                  <small class="text-muted me-2" style="min-width: 80px;">{{this.day}}</small>
                  <div class="flex-grow-1">
                    <div class="progress" style="height: 18px;">
                      <div class="progress-bar bg-primary" role="progressbar" style="width: {{this.widthPercent}}%;" aria-valuenow="{{this.widthPercent}}" aria-valuemin="0" aria-valuemax="100">
                        {{this.count}}
                      </div>
                    </div>
                  </div>
                </div>
              {{/each}}
            {{else}}
              <p class="text-muted mb-0">No daily data available.</p>
            {{/if}}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
