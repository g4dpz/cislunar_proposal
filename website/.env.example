# SMTP Configuration for contact form email notifications
# Copy this file to .env and fill in your SMTP credentials.
# If SMTP_HOST is not set, email sending is disabled (form submissions
# are still saved to the local SQLite database).

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@cislunar-dtn.org
SMTP_TO=dave@g4dpz.me.uk
SMTP_USE_TLS=true
